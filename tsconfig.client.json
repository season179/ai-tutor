{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "noEmit": true,
    "sourceMap": true
  },
  "include": [
    "src/client/**/*.ts",
    "src/client/**/*.tsx",
    "src/router.tsx",
    "src/routes/**/*.ts",
    "src/routes/**/*.tsx",
    "src/routeTree.gen.ts",
    // Server functions are imported by the client to be *called*, so tsc follows
    // their handler bodies into `cloudflare:workers` and the workerd runtime
    // globals (D1Database, R2Bucket, …). The Start plugin strips those handlers
    // from the client bundle, but the type-checker still needs the declarations.
    //
    // We load `worker-configuration.client.d.ts` — the generated bindings with the
    // workerd HTMLRewriter globals (the DOM-colliding `Element`/`Comment`/`Text`/…)
    // stripped by scripts/strip-worker-types.mjs — instead of the raw generated
    // file. That keeps the DOM `Element.append()` from being silently widened to
    // accept workerd-only `ReadableStream`/`Response` args.
    "worker-configuration.client.d.ts"
  ]
}
