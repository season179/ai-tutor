{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node", "@cloudflare/workers-types"],
    "noEmit": true,
    "sourceMap": true
  },
  "include": [
    // All server-side module code, the shared kernel, and the external-API adapter.
    "src/core/**/*.ts",
    "src/providers/**/*.ts",
    "src/modules/**/*.ts",
    "src/server-request-context.ts",
    "src/worker.ts",
    // The generated binding types define the ambient `Env` the Worker entry uses;
    // `core/env.ts` is the hand-written canonical shape, but the worker still sees
    // workerd's runtime globals (ExportedHandler, DurableObjectNamespace, …) here.
    "worker-configuration.d.ts"
  ],
  "exclude": [
    // Client UI has its own DOM/Vite config and must not be re-checked here.
    "src/client"
  ]
}
